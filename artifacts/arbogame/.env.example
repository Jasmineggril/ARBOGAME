# Supabase Configuration
# Obtenha estes valores em: https://supabase.com/dashboard

# URL do seu projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima (pública) do Supabase
VITE_SUPABASE_ANON_KEY=sua-chave-anonima-aqui

# Nota: Variáveis com prefixo VITE_ são expostas ao cliente (frontend)
# Não adicione senhas ou tokens privados com este prefixo
